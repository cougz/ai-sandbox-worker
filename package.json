{
  "name": "ai-sandbox-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "prebuild": "./script/build-opencode-ui",
    "build": "echo 'Worker build: OpenCode UI bundle generated in prebuild'",
    "build-ui": "./script/build-opencode-ui",
    "deploy:local": "wrangler deploy",
    "deploy:ci": "node scripts/patch-container-image.js && wrangler deploy --config wrangler.deploy.json",
    "container:build": "wrangler containers build . -p -t ai-sandbox-chat:v$(date +%Y-%m-%d)",
    "types": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/codemode": "^0.3.0",
    "@cloudflare/sandbox": "0.8.9",
    "@cloudflare/shell": "^0.3.0",
    "@cloudflare/worker-bundler": "^0.0.4",
    "@cloudflare/workers-oauth-provider": "^0.2.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opencode-ai/sdk": "^1.0.137",
    "agents": "^0.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
